{
  "name": "@spaguettiscope/plugin-electron",
  "version": "2.0.0",
  "description": "Electron scan plugin for SpaguettiScope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonsantos/spaguettiscope.git",
    "directory": "plugins/electron"
  },
  "homepage": "https://github.com/jasonsantos/spaguettiscope",
  "bugs": {
    "url": "https://github.com/jasonsantos/spaguettiscope/issues"
  },
  "keywords": [
    "electron",
    "desktop",
    "spaguettiscope",
    "plugin"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@spaguettiscope/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
