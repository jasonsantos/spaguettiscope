{
  "name": "@spaguettiscope/cli",
  "version": "1.0.1",
  "description": "Beautiful command-line interface for SpaguettiScope code entropy analyzer",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "spasco": "bin/spasco.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/**/*.js",
    "bin/**/*.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "echo 'Building CLI...'",
    "dev": "echo 'CLI development mode...'",
    "test": "echo 'Testing CLI...'",
    "lint": "echo 'Linting CLI...'",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run test && npm run lint"
  },
  "keywords": [
    "cli",
    "code-analysis",
    "entropy",
    "spaguettiscope",
    "terminal",
    "developer-tools",
    "static-analysis"
  ],
  "author": "Jason Santos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonsantos/spaguettiscope.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/jasonsantos/spaguettiscope/issues"
  },
  "homepage": "https://github.com/jasonsantos/spaguettiscope#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@spaguettiscope/core": "^1.0.0",
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.12",
    "figlet": "^1.7.0",
    "gradient-string": "^2.0.2",
    "cli-table3": "^0.6.3",
    "boxen": "^7.1.1",
    "terminal-link": "^3.0.0"
  }
}
