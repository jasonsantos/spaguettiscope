{
  "name": "@spaguettiscope/cli",
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "spasco": "bin/spasco.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "bin/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@spaguettiscope/core": "workspace:*",
    "@spaguettiscope/reports": "workspace:*",
    "boxen": "latest",
    "chalk": "latest",
    "commander": "latest",
    "figlet": "latest",
    "gradient-string": "latest",
    "ora": "latest",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@spaguettiscope/plugin-nextjs": "workspace:*",
    "@types/figlet": "latest",
    "@types/gradient-string": "latest",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "latest",
    "vitest": "latest"
  }
}
