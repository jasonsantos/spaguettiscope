{
  "name": "@spaguettiscope/reports",
  "version": "2.0.0",
  "description": "Connectors, aggregation, and HTML dashboard renderer for SpaguettiScope",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonsantos/spaguettiscope.git",
    "directory": "packages/reports"
  },
  "homepage": "https://github.com/jasonsantos/spaguettiscope",
  "bugs": {
    "url": "https://github.com/jasonsantos/spaguettiscope/issues"
  },
  "keywords": [
    "dashboard",
    "testing",
    "coverage",
    "html",
    "report"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm build:renderer && tsc --project tsconfig.json",
    "build:renderer": "vite build --config src/renderer/html/vite.config.ts",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@spaguettiscope/core": "workspace:*",
    "recharts": "^3.8.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
