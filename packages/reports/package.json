{
  "name": "@spaguettiscope/reports",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm build:renderer && tsc --project tsconfig.json",
    "build:renderer": "vite build --config src/renderer/html/vite.config.ts",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@spaguettiscope/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "jsdom": "latest",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.8.1",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
